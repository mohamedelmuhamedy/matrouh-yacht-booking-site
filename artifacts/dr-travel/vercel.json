{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && cd artifacts/dr-travel && pnpm exec vite build --config vite.config.ts",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/googleaebab8491e2a6175.html", "destination": "/googleaebab8491e2a6175.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
